<div class="login-page">
  <div class="login-logo">
    <img src="<%= basePath %>/logo.png" alt="MonPlex" />
  </div>

  <div class="login-card">
    <h1><%= t("login.title") %></h1>
    <% if (typeof error !== 'undefined' && error === 'unauthorized') { %>
    <div class="login-error"><%= t("login.unauthorized", { serverName: plexServerName }) %></div>
    <% } %>
    <a class="plex-btn plex-btn--logo" href="<%= basePath %>/login" aria-label="<%= t('login.withPlex') %>">
      <img src="<%= basePath %>/img/plex-alt-light.svg" alt="Plex" class="plex-btn-logo" />
      <span class="sr-only"><%= t("login.withPlex") %></span>
    </a>
  </div>
</div>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .plex-btn--logo {
    min-width: 240px;
  }

  .plex-btn-logo {
    width: 110px;
    height: auto;
    display: block;
  }

  .login-error {
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.4);
    color: #fca5a5;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 0.88rem;
    text-align: center;
  }
</style>
