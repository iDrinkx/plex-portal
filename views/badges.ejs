<style>
  .badges-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  /* HEADER */
  .badges-header {
    margin-bottom: 50px;
  }

  .badges-title {
    font-size: 42px;
    font-weight: bold;
    color: #E5A00D;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 10px;
  }

  .badges-subtitle {
    font-size: 14px;
    color: #a0a0a0;
    margin-bottom: 30px;
  }

  /* STATS */
  .badges-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .stat-box {
    background: linear-gradient(135deg, rgba(139, 69, 19, 0.2), rgba(218, 165, 32, 0.1));
    border: 2px solid rgba(218, 165, 32, 0.3);
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .stat-number {
    font-size: 36px;
    font-weight: bold;
    color: #E5A00D;
    display: block;
  }

  .stat-label {
    font-size: 12px;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 8px;
  }

  /* CATEGORIES */
  .achievements-section {
    margin-bottom: 50px;
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .category-icon {
    font-size: 28px;
  }

  .category-name {
    font-size: 24px;
    font-weight: bold;
    color: #fff;
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 20px;
  }

  /* ACHIEVEMENT CARD */
  .achievement-card {
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .achievement-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .achievement-card.locked {
    opacity: 0.6;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .achievement-card.locked .achievement-icon {
    filter: grayscale(100%);
    opacity: 0.5;
  }

  /* Couleurs de bordure par catégorie */
  .achievement-card.temporels {
    border-left: 4px solid #E67E22;
  }

  .achievement-card.activites {
    border-left: 4px solid #E74C3C;
  }

  .achievement-card.films {
    border-left: 4px solid #E67E22;
  }

  .achievement-card.series {
    border-left: 4px solid #3498DB;
  }

  .achievement-card.mensuels {
    border-left: 4px solid #F39C12;
  }

  .achievement-card.secrets {
    border-left: 4px solid #9B59B6;
  }

  .achievement-icon {
    font-size: 40px;
    margin-bottom: 12px;
    display: block;
  }

  .achievement-name {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
    line-height: 1.3;
    min-height: 32px;
  }

  .achievement-date {
    font-size: 11px;
    color: #8BC34A;
  }

  .achievement-date.secret {
    color: #9B59B6;
  }

  .achievement-secret-text {
    font-size: 11px;
    color: #9B59B6;
  }

  /* TOOLTIP */
  .achievement-tooltip {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.95);
    color: #fff;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 12px;
    white-space: nowrap;
    margin-bottom: 8px;
    z-index: 10;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .achievement-card:hover .achievement-tooltip {
    display: block;
  }

  /* Loading state */
  .loading {
    text-align: center;
    padding: 60px 20px;
    color: #a0a0a0;
  }

  .spinner {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 3px solid rgba(229, 160, 13, 0.3);
    border-top: 3px solid #E5A00D;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .badges-title {
      font-size: 28px;
    }

    .achievements-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 15px;
    }

    .achievement-card {
      padding: 15px;
    }

    .achievement-icon {
      font-size: 32px;
    }

    .achievement-tooltip {
      display: none !important;
    }
  }
</style>

<div class="badges-container">
  <!-- HEADER -->
  <div class="badges-header">
    <h1 class="badges-title">Mes Badges</h1>
    <p class="badges-subtitle">Débloquez des badges en regardant du contenu sur Minimax TV !</p>
  </div>

  <!-- STATS -->
  <div class="badges-stats">
    <div class="stat-box">
      <span class="stat-number" id="unlockedCount"><%= stats.unlocked %></span>
      <span class="stat-label">Badges Débloqués</span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="lockedCount"><%= stats.locked %></span>
      <span class="stat-label">Badges Restants</span>
    </div>
    <div class="stat-box">
      <span class="stat-number" id="progressPercent"><%= stats.progress %>%</span>
      <span class="stat-label">Progression</span>
    </div>
  </div>

  <!-- ACHIEVEMENTS BY CATEGORY -->
  <% const categories = ['temporels', 'activites', 'films', 'series', 'mensuels', 'secrets']; %>
  
  <% categories.forEach(categoryKey => {
    const category = ACHIEVEMENTS[categoryKey];
    if (!category || !category.achievements || category.achievements.length === 0) return;
  %>
    <div class="achievements-section">
      <div class="category-header">
        <span class="category-icon"><%= category.icon %></span>
        <span class="category-name"><%= category.name %></span>
      </div>

      <div class="achievements-grid">
        <% category.achievements.forEach(achievement => { %>
          <div class="achievement-card <%= achievement.category %> <%= achievement.unlocked ? 'unlocked' : 'locked' %>">
            <span class="achievement-icon"><%= achievement.icon %></span>
            <div class="achievement-name"><%= achievement.name %></div>
            
            <% if (achievement.unlocked) { %>
              <div class="achievement-date">
                <% if (achievement.unlockedDate) { %>
                  Débloqué le <%= achievement.unlockedDate %>
                <% } else { %>
                  ✓ Débloqué
                <% } %>
              </div>
            <% } else { %>
              <% if (achievement.isSecret) { %>
                <div class="achievement-secret-text">🔒 Badge secret</div>
              <% } else { %>
                <div class="achievement-tooltip"><%= achievement.description %></div>
              <% } %>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% }); %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Les données sont déjà affichées via EJS
    console.log("🏆 Page Badges chargée!");
  });
</script>
