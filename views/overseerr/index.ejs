<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Seerr – Demandes de contenu</title>
  <link rel="stylesheet" href="<%= basePath %>/css/style.css" />
  <link rel="stylesheet" href="<%= basePath %>/css/overseerr.css" />
  <script>window.APP_BASE_PATH = "<%= basePath %>";</script>
</head>
<body class="overseerr-page">

<div class="seerr-layout">

  <!-- ====== SIDEBAR ====== -->
  <aside class="seerr-sidebar" id="seerrSidebar">

    <!-- Logo -->
    <a href="<%= basePath %>/dashboard" class="seerr-logo">
      <div class="seerr-logo-icon">🎬</div>
      <span class="seerr-logo-text">seerr</span>
    </a>

    <!-- Nav -->
    <nav class="seerr-nav">
      <div class="seerr-nav-section">
        <div class="seerr-nav-label">Navigation</div>
        <button class="seerr-nav-item active" id="nav-discover">
          <span class="seerr-nav-icon">🧭</span> Découvrir
        </button>
        <button class="seerr-nav-item" id="nav-movies">
          <span class="seerr-nav-icon">🎞️</span> Films
        </button>
        <button class="seerr-nav-item" id="nav-tv">
          <span class="seerr-nav-icon">📺</span> Séries
        </button>
      </div>

      <div class="seerr-nav-section">
        <div class="seerr-nav-label">Gestion</div>
        <button class="seerr-nav-item" id="nav-requests">
          <span class="seerr-nav-icon">📋</span>
          Mes demandes
          <span class="seerr-nav-badge" id="pendingRequestsBadge" style="display:none">0</span>
        </button>
      </div>
    </nav>

    <!-- Footer user -->
    <div class="seerr-sidebar-footer">
      <!-- Quota films -->
      <div class="seerr-quota" id="movieQuota" style="display:none">
        <div class="seerr-quota-label">
          <span>Films &amp; quotas <span class="seerr-quota-days" id="movieQuotaDays" style="color:var(--seerr-text-muted)"></span></span>
          <span id="movieQuotaUsed" class="seerr-quota-used">0/0</span>
        </div>
        <div class="seerr-quota-bar">
          <div class="seerr-quota-fill" style="width:0%"></div>
        </div>
      </div>

      <!-- Quota séries -->
      <div class="seerr-quota" id="tvQuota" style="display:none">
        <div class="seerr-quota-label">
          <span>Séries &amp; quotas <span class="seerr-quota-days" id="tvQuotaDays" style="color:var(--seerr-text-muted)"></span></span>
          <span id="tvQuotaUsed" class="seerr-quota-used">0/0</span>
        </div>
        <div class="seerr-quota-bar">
          <div class="seerr-quota-fill" style="width:0%"></div>
        </div>
      </div>

      <!-- User mini -->
      <a href="<%= basePath %>/profil" class="seerr-user-mini" style="margin-top:12px">
        <% if (user && user.thumb) { %>
          <img class="seerr-user-avatar" src="<%= user.thumb %>" alt="">
        <% } else { %>
          <div class="seerr-user-avatar-placeholder"><%= (user && user.username) ? user.username[0].toUpperCase() : '?' %></div>
        <% } %>
        <div class="seerr-user-info">
          <div class="seerr-user-name" id="seerrUserName"><%= (user && user.username) ? user.username : 'Utilisateur' %></div>
          <div class="seerr-user-role" id="seerrUserRole">Membre</div>
        </div>
      </a>

      <!-- Retour dashboard -->
      <a href="<%= basePath %>/dashboard" class="seerr-nav-item" style="margin-top:8px;border-radius:7px;text-decoration:none">
        <span class="seerr-nav-icon">🏠</span> Dashboard
      </a>
    </div>

  </aside>

  <!-- Overlay sidebar mobile -->
  <div class="seerr-sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ====== MAIN ====== -->
  <div class="seerr-main">

    <!-- Topbar -->
    <header class="seerr-topbar">
      <button class="seerr-burger" id="seerrBurger" aria-label="Menu">☰</button>

      <div class="seerr-search-wrap">
        <span class="seerr-search-icon">🔍</span>
        <input
          type="search"
          class="seerr-search"
          id="seerrSearchInput"
          placeholder="Rechercher un film ou une série..."
          autocomplete="off"
        />
      </div>

      <div class="seerr-topbar-actions">
        <% if (user && user.thumb) { %>
          <img src="<%= user.thumb %>" style="width:32px;height:32px;border-radius:50%;object-fit:cover" alt="">
        <% } %>
      </div>
    </header>

    <!-- Content -->
    <main class="seerr-content">

      <!-- ══ VUE : DÉCOUVRIR ══ -->
      <div class="seerr-view active" id="view-discover">
        <div class="seerr-section">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">🎉 Récemment ajoutés — Films</h2>
            <button class="seerr-section-more" id="nav-movies-link">Voir tout →</button>
          </div>
          <div class="seerr-media-row" id="rowMovies">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>

        <div class="seerr-section">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">📺 Récemment ajoutés — Séries</h2>
            <button class="seerr-section-more" id="nav-tv-link">Voir tout →</button>
          </div>
          <div class="seerr-media-row" id="rowTV">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>

        <div class="seerr-section">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">🔥 Tendances</h2>
          </div>
          <div class="seerr-media-row" id="rowTrending">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>

        <div class="seerr-section" id="sectionUpcomingMovies">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">🎞️ À venir — Films</h2>
          </div>
          <div class="seerr-media-row" id="rowUpcomingMovies">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>

        <div class="seerr-section" id="sectionUpcomingTV">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">📅 À venir — Séries</h2>
          </div>
          <div class="seerr-media-row" id="rowUpcomingTV">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>

        <div class="seerr-section" id="sectionWatchlist">
          <div class="seerr-section-header">
            <h2 class="seerr-section-title">📌 Ma liste Plex</h2>
          </div>
          <div class="seerr-media-row" id="rowWatchlist">
            <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
          </div>
        </div>
      </div>

      <!-- ══ VUE : FILMS ══ -->
      <div class="seerr-view" id="view-movies">
        <div class="seerr-section-header" style="margin-bottom:20px">
          <h2 class="seerr-section-title">🎞️ Films</h2>
        </div>
        <div class="seerr-media-grid" id="gridMovies">
          <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
        </div>
      </div>

      <!-- ══ VUE : SÉRIES ══ -->
      <div class="seerr-view" id="view-tv">
        <div class="seerr-section-header" style="margin-bottom:20px">
          <h2 class="seerr-section-title">📺 Séries</h2>
        </div>
        <div class="seerr-media-grid" id="gridTV">
          <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
        </div>
      </div>

      <!-- ══ VUE : DEMANDES ══ -->
      <div class="seerr-view" id="view-requests">
        <div class="seerr-section-header" style="margin-bottom:16px">
          <h2 class="seerr-section-title">📋 Mes demandes</h2>
        </div>
        <div class="seerr-requests-filters">
          <button class="seerr-filter-btn active" data-filter="all">Toutes</button>
          <button class="seerr-filter-btn" data-filter="pending">En attente</button>
          <button class="seerr-filter-btn" data-filter="approved">Approuvées</button>
          <button class="seerr-filter-btn" data-filter="available">Disponibles</button>
          <button class="seerr-filter-btn" data-filter="declined">Refusées</button>
        </div>
        <div id="requestsContainer">
          <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
        </div>
      </div>

      <!-- ══ VUE : RECHERCHE ══ -->
      <div class="seerr-view" id="view-search">
        <div class="seerr-section-header" style="margin-bottom:20px">
          <h2 class="seerr-section-title" id="searchTitle">Résultats</h2>
        </div>
        <div class="seerr-media-grid" id="searchGrid">
          <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
        </div>
      </div>

    </main>
  </div>

</div>

<!-- ====== MODAL ====== -->
<div class="seerr-modal-overlay" id="seerrModal">
  <div class="seerr-modal">
    <button class="seerr-modal-close" id="seerrModalClose">✕</button>
    <div id="seerrModalBody">
      <div class="seerr-loading"><div class="seerr-spinner"></div> Chargement...</div>
    </div>
  </div>
</div>

<!-- ====== TOASTS ====== -->
<div class="seerr-toast-container" id="seerrToasts"></div>

<script src="<%= basePath %>/js/overseerr.js"></script>
<script>
  // Liens "Voir tout" dans la vue discover
  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("nav-movies-link")?.addEventListener("click", () => {
      document.getElementById("nav-movies")?.click();
    });
    document.getElementById("nav-tv-link")?.addEventListener("click", () => {
      document.getElementById("nav-tv")?.click();
    });
  });
</script>

</body>
</html>
