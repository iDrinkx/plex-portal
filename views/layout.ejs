<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="<%= basePath %>/css/style.css" />
  <link rel="icon" type="image/png" href="<%= basePath %>/logo.png" />
  <link rel="apple-touch-icon" href="<%= basePath %>/logo.png" />
  <title>Plex-Portal</title>
  <script>
    window.APP_BASE_PATH = "<%= basePath %>";
  </script>
</head>
<body <% if (user) { %>data-user-id="<%= user.id %>"<% } %>>

<% if (user) { %>
  <nav class="navbar">

    <!-- Logo -->
    <a href="<%= basePath %>/dashboard" class="brand">
      <img class="brand-logo" src="<%= basePath %>/logo.png" alt="MonPlex"/>
    </a>

    <!-- Desktop Menu -->
    <div class="nav-center desktop-menu">
      <a href="<%= basePath %>/dashboard" class="nav-link">Dashboard&nbsp;🏠</a>
      <a href="<%= basePath %>/profil" class="nav-link nav-link-profil">Profil&nbsp;👤</a>
      <a href="<%= basePath %>/classement" class="nav-link nav-link-classement">Classement&nbsp;🏆</a>
      <a href="<%= basePath %>/mes-stats" class="nav-link nav-link-stats">Statistiques&nbsp;📊</a>
      <a href="<%= basePath %>/seerr" class="nav-link nav-link-demandes">Demandes&nbsp;<img src="<%= basePath %>/img/seerr-icon.png" alt="Seerr" class="nav-seerr-logo"></a>
    </div>

    <!-- Desktop Logout -->
    <div class="nav-right desktop-menu">
      <a href="<%= basePath %>/profil" class="nav-sub-pill" id="navSubPill">&#x2014;</a>
      <a class="logout-btn" href="<%= basePath %>/logout">Déconnexion</a>
    </div>

    <!-- Pill abonnement mobile -->
    <a href="<%= basePath %>/profil" class="nav-sub-pill mobile-sub-pill" id="mobileSubPill">&#x2014;</a>
    <!-- Burger Mobile -->
    <div class="burger" id="burger">☰</div>

  </nav>

  <!-- Overlay -->
  <div class="overlay" id="overlay"></div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="<%= basePath %>/dashboard">Dashboard&nbsp;🏠</a>
    <a href="<%= basePath %>/profil">Profil&nbsp;👤</a>
    <a href="<%= basePath %>/classement">Classement&nbsp;🏆</a>
    <a href="<%= basePath %>/mes-stats">Statistiques&nbsp;📊</a>
    <a href="<%= basePath %>/seerr">Demandes <img src="<%= basePath %>/img/seerr-icon.png" alt="Seerr" class="nav-seerr-logo"></a>
    <a href="<%= basePath %>/logout" class="logout-mobile">Déconnexion</a>
  </div>

<% } %>

<main class="content">
  <%- body %>
</main>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    const burger = document.getElementById("burger");
    const mobileMenu = document.getElementById("mobileMenu");
    const overlay = document.getElementById("overlay");

    if (!burger || !mobileMenu || !overlay) return;

    const openMenu = () => {
      mobileMenu.classList.add("open");
      overlay.classList.add("active");
      document.body.style.overflow = "hidden"; // bloque le scroll
    };

    const closeMenu = () => {
      mobileMenu.classList.remove("open");
      overlay.classList.remove("active");
      document.body.style.overflow = "";
    };

    // Toggle burger
    burger.addEventListener("click", () => {
      if (mobileMenu.classList.contains("open")) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Click overlay
    overlay.addEventListener("click", closeMenu);

    // Ferme le menu quand on clique sur un lien
    document.querySelectorAll(".mobile-menu a").forEach(link => {
      link.addEventListener("click", closeMenu);
    });

  });

  // --- Bulle abonnement navbar ---
  (function () {
    const pill   = document.getElementById('navSubPill');
    const userId = document.body.getAttribute('data-user-id') || 'guest';
    if (!pill) return;

    const PILL_KEY = 'nav_pill_snap:' + userId;
    const PILL_TTL = 24 * 60 * 60 * 1000; // 24 h

    function applyPill(data) {
      const numMatch = data.daysLeft && String(data.daysLeft).match(/\d+/);
      const text = data.status === 'unlimited' ? '\u221e'
                 : numMatch ? numMatch[0] + '\u00a0jours'
                 : data.label || '\u2014';
      const cls = 'nav-sub-pill--' + (data.status || 'loading');
      [pill, document.getElementById('mobileSubPill')].forEach(el => {
        if (!el) return;
        el.textContent = text;
        el.className = el.className.replace(/\bnav-sub-pill--\S+/g, '');
        el.classList.add(cls);
      });
    }

    // ⚡ Restaurer instantanément depuis le cache
    try {
      const raw = localStorage.getItem(PILL_KEY);
      if (raw) {
        const snap = JSON.parse(raw);
        if (snap.savedAt && Date.now() - snap.savedAt < PILL_TTL) applyPill(snap);
      }
    } catch (_) {}

    // Puis rafraîchir en arrière-plan
    fetch((window.APP_BASE_PATH || '') + '/api/subscription')
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (!data) return;
        applyPill(data);
        try { localStorage.setItem(PILL_KEY, JSON.stringify({ ...data, savedAt: Date.now() })); } catch (_) {}
      })
      .catch(() => {});
  })();

</script>

<!-- Version Footer & Changelog Modal -->
<footer class="version-footer" id="versionFooter">
  <span class="version-text">
    <span class="version-number" id="versionNumber">v--</span>
    <span class="version-badge" id="versionBadge">Vérification...</span>
  </span>
</footer>

<!-- Changelog Modal -->
<div class="changelog-modal" id="changelogModal">
  <div class="changelog-modal-content">
    <div class="changelog-header">
      <h2>Changelog - v<span id="changelogVersion">--</span></h2>
      <button class="changelog-close" id="changelogClose">✕</button>
    </div>
    <div class="changelog-body" id="changelogBody">
      <p style="text-align: center; color: #888;">Chargement du changelog...</p>
    </div>
  </div>
</div>

<script>
  // Version Footer & Changelog Management
  (function() {
    const versionNumber = document.getElementById('versionNumber');
    const versionBadge = document.getElementById('versionBadge');
    const versionFooter = document.getElementById('versionFooter');
    const changelogModal = document.getElementById('changelogModal');
    const changelogClose = document.getElementById('changelogClose');
    const changelogBody = document.getElementById('changelogBody');
    const changelogVersion = document.getElementById('changelogVersion');

    // Fetch version from API
    async function loadVersion() {
      try {
        const response = await fetch((window.APP_BASE_PATH || '') + '/api/version');
        if (!response.ok) throw new Error('Failed to fetch version');
        const { version } = await response.json();
        versionNumber.textContent = 'v' + version;
        changelogVersion.textContent = version;
        versionBadge.textContent = '✓ À jour';
        versionBadge.className = 'version-badge version-badge--latest';
      } catch (err) {
        versionNumber.textContent = 'v?.?.?';
        versionBadge.textContent = 'Erreur';
        versionBadge.className = 'version-badge version-badge--error';
      }
    }

    // Load changelog from file
    async function loadChangelog() {
      try {
        const response = await fetch((window.APP_BASE_PATH || '') + '/CHANGELOG.md');
        if (!response.ok) throw new Error('Failed to fetch changelog');
        const markdown = await response.text();
        changelogBody.innerHTML = '<pre style="white-space: pre-wrap; word-wrap: break-word; font-size: 0.9em; line-height: 1.6;">' +
                                  markdown.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
                                  '</pre>';
      } catch (err) {
        changelogBody.innerHTML = '<p style="color: #e74c3c;">Impossible de charger le changelog.</p>';
      }
    }

    // Open modal on footer click
    versionFooter.addEventListener('click', () => {
      if (!changelogBody.textContent.includes('Chargement')) {
        // Already loaded, just show
        changelogModal.classList.add('active');
      } else {
        // First load
        loadChangelog().then(() => {
          changelogModal.classList.add('active');
        });
      }
    });

    // Close modal
    changelogClose.addEventListener('click', () => {
      changelogModal.classList.remove('active');
    });

    changelogModal.addEventListener('click', (e) => {
      if (e.target === changelogModal) {
        changelogModal.classList.remove('active');
      }
    });

    // Load version on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadVersion);
    } else {
      loadVersion();
    }
  })();
</script>

</body>
</html>
